<style>
  .ssc-page {
    min-height: 100vh;
    background: var(--color-bg);
    padding: 40px 16px;
    font-family: var(--font-body);
  }
  .ssc-inner { max-width: 720px; margin: 0 auto; }
  .ssc-header { text-align: center; margin-bottom: 40px; }
  .ssc-title {
    font-family: var(--font-display);
    font-size: 42px;
    letter-spacing: -0.02em;
    color: #F0EEE8;
    margin-bottom: 8px;
    line-height: 1.1;
  }
  .ssc-title span { font-style: italic; color: var(--color-primary); }
  .ssc-subtitle {
    font-size: 16px;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ssc-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    margin-bottom: 16px;
    position: relative;
    overflow: hidden;
  }
  .ssc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }
  .ssc-card-title {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: var(--space-6);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ssc-details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .ssc-detail-item { display: flex; flex-direction: column; gap: 4px; }
  .ssc-detail-label { font-size: 11px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.15em; }
  .ssc-detail-value { font-size: 15px; color: #F0EEE8; font-weight: 500; }
  .ssc-weather-row { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 8px; justify-content: center; flex-wrap: wrap; }
  .ssc-weather-row::-webkit-scrollbar { height: 4px; }
  .ssc-weather-row::-webkit-scrollbar-track { background: var(--color-border); border-radius: 2px; }
  .ssc-weather-row::-webkit-scrollbar-thumb { background: var(--color-primary); border-radius: 2px; }
  .ssc-weather-day {
    min-width: 76px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 14px 8px;
    text-align: center;
    flex-shrink: 0;
  }
  .ssc-weather-dow { font-size: 11px; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }
  .ssc-weather-icon { font-size: 24px; margin-bottom: 8px; }
  .ssc-weather-temp { font-size: 14px; font-weight: 700; color: #F0EEE8; }
  .ssc-weather-rain { font-size: 12px; color: var(--color-accent); margin-top: 4px; }
  .ssc-traveler-title { font-size: 16px; font-weight: 600; color: #F0EEE8; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
  .ssc-traveler-badge { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 8px; border-radius: var(--radius-pill); }
  .ssc-traveler-badge.adult { background: rgba(201,168,76,0.15); color: var(--color-primary); border: 1px solid rgba(201,168,76,0.25); }
  .ssc-traveler-badge.child { background: rgba(62,207,178,0.15); color: var(--color-accent); border: 1px solid rgba(62,207,178,0.25); }
  .ssc-table { width: 100%; border-collapse: collapse; }
  .ssc-table thead tr { border-bottom: 1px solid var(--color-border); }
  .ssc-table th { font-size: 11px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-text-muted); padding: 0 0 12px 0; text-align: left; }
  .ssc-table th:nth-child(2), .ssc-table td:nth-child(2) { text-align: left; width: 60px; }
  .ssc-table th:nth-child(3), .ssc-table td:nth-child(3) { text-align: center; width: 40px; }
  .ssc-table tbody tr { border-bottom: 1px solid rgba(46,51,71,0.5); transition: background var(--transition-fast); }
  .ssc-table tbody tr:last-child { border-bottom: none; }
  .ssc-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .ssc-table td { padding: 12px 0; color: #F0EEE8; font-size: 14px; }
  .ssc-table td:last-child { text-align: right; }
  .ssc-qty-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 24px;
    padding: 0 8px;
    background: var(--color-primary-dim);
    color: var(--color-primary-light);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 600;
  }
  .ssc-capacity-label { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .ssc-capacity-title { font-size: 13px; font-weight: 600; color: #F0EEE8; }
  .ssc-capacity-pct { font-size: 13px; font-weight: 700; color: var(--color-primary); }
  .ssc-capacity-pct.over { color: var(--color-error); }
  .ssc-progress-track { height: 8px; background: var(--color-border); border-radius: var(--radius-pill); overflow: hidden; margin-bottom: 16px; }
  .ssc-progress-fill { height: 100%; border-radius: var(--radius-pill); background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light)); transition: width 0.6s ease; }
  .ssc-progress-fill.over { background: linear-gradient(90deg, var(--color-error), #f08080); }
  .ssc-alert { display: flex; align-items: flex-start; gap: 12px; padding: 16px; border-radius: var(--radius-md); font-size: 14px; }
  .ssc-alert.success { background: rgba(62,207,178,0.1); border: 1px solid rgba(62,207,178,0.25); color: var(--color-accent); }
  .ssc-alert.danger { background: rgba(224,92,92,0.1); border: 1px solid rgba(224,92,92,0.25); color: #E05C5C; }
  .ssc-alert-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .ssc-alert strong { display: block; margin-bottom: 2px; }
  .ssc-cta { text-align: center; margin-top: 32px; margin-bottom: 120px; } 
  .ssc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .ssc-btn:hover { background: var(--color-primary-light); color: var(--color-text-inverse); box-shadow: var(--shadow-gold); transform: translateY(-1px); }
  .ssc-divider { height: 1px; background: var(--color-border); margin: 24px 0; }
  .ssc-optional-section { margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--color-border); }
  .ssc-optional-label { font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 12px; }
  .ssc-optional-control { display: flex; align-items: center; justify-content: space-between; }
  .ssc-optional-name { font-size: 14px; color: #F0EEE8; }
  .ssc-counter { display: flex; align-items: center; gap: 12px; }
  .ssc-counter-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    color: #F0EEE8;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
    font-family: var(--font-body);
    line-height: 1;
  }
  .ssc-counter-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .ssc-counter-value { font-size: 16px; font-weight: 700; color: #F0EEE8; min-width: 20px; text-align: center; }
  .ssc-bag-radio-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(46,51,71,0.5);
    cursor: pointer;
  }
  .ssc-bag-radio-row:last-child { border-bottom: none; }
  .ssc-bag-radio-row input[type="radio"] {
    width: 18px;
    height: 18px;
    accent-color: var(--color-primary);
    cursor: pointer;
    flex-shrink: 0;
  }
  .ssc-bag-radio-label { font-size: 14px; color: #F0EEE8; }
  .ssc-bag-radio-pts { margin-left: auto; font-size: 12px; color: var(--color-text-muted); }
</style>

<div class="ssc-page">
  <div class="ssc-inner">

    <div class="ssc-header">
      <h1 class="ssc-title">Your <span>Packing List</span></h1>
      <div class="ssc-subtitle"><%= @trip.destination.titleize %></div>
    </div>

    <!-- Trip Details -->
    <div class="ssc-card">
      <div class="ssc-card-title"><i class="bi bi-info-circle"></i> Trip Details</div>
      <div class="ssc-details-grid">
        <div class="ssc-detail-item">
          <span class="ssc-detail-label"><i class="bi bi-geo-alt"></i> Destination</span>
          <span class="ssc-detail-value"><%= @trip.destination.titleize %></span>
        </div>
        <div class="ssc-detail-item">
          <span class="ssc-detail-label"><i class="bi bi-calendar-range"></i> Dates</span>
          <span class="ssc-detail-value"><%= @trip.start_date.strftime("%b %d") %> — <%= @trip.end_date.strftime("%b %d, %Y") %></span>
        </div>
        <div class="ssc-detail-item">
          <span class="ssc-detail-label"><i class="bi bi-compass"></i> Type</span>
          <span class="ssc-detail-value"><%= @trip.trip_type.titleize %></span>
        </div>
        <div class="ssc-detail-item">
          <span class="ssc-detail-label"><i class="bi bi-luggage"></i> Luggage</span>
          <span class="ssc-detail-value"><%= @trip.luggage_type.titleize %></span>
        </div>
      </div>
    </div>

    <!-- Weather Forecast -->
    <% if @result[:forecast]&.any? %>
      <div class="ssc-card">
        <div class="ssc-card-title"><i class="bi bi-cloud-sun"></i> Weather Forecast</div>
        <div class="ssc-weather-row">
          <% @result[:forecast].each do |day| %>
            <div class="ssc-weather-day">
              <div class="ssc-weather-dow"><%= day[:date].strftime("%a") %></div>
              <div class="ssc-weather-icon">
                <%= case day[:icon]
                    when "Clear"        then "☀️"
                    when "Clouds"       then "☁️"
                    when "Rain"         then "🌧️"
                    when "Drizzle"      then "🌦️"
                    when "Thunderstorm" then "⛈️"
                    when "Snow"         then "❄️"
                    else "🌤️"
                    end %>
              </div>
              <div class="ssc-weather-temp"><%= day[:temp] %>°C</div>
              <% if day[:rain] %><div class="ssc-weather-rain">☔</div><% end %>
            </div>
          <% end %>
        </div>
        <p style="margin-top:12px; font-size:12px; color:var(--color-text-muted); text-align:center; font-style:italic;">
          Weather shown covers the next 7 days — update your trip at D-2 for a more accurate list.
        </p>
      </div>
    <% end %>

    <!-- Accessories + Capacity wrapper -->
    <div data-controller="accessories"
         data-accessories-total-value="<%= @result[:total_points] %>"
         data-accessories-capacity-value="<%= @result[:capacity] %>">

      <!-- Packing list par voyageur -->
      <% @result[:packing_per_traveler].each_with_index do |entry, index| %>
        <%
          is_main    = index == 0
          has_basket = is_main && @trip.sport
        %>
        <div class="ssc-card"
             data-traveler-card
             data-sport-has-basket="<%= has_basket %>">

          <div class="ssc-traveler-title">
            <%= entry[:traveler].role == "child" ? "👦" : "👤" %>
            <%= entry[:traveler].name %>
            <span class="ssc-traveler-badge <%= entry[:traveler].role %>">
              <%= entry[:traveler].role == "child" ? "Enfant" : "Adulte" %>
            </span>
          </div>

          <table class="ssc-table">
            <thead>
              <tr><th>Item</th><th>Qty</th><th>Check</th></tr>
            </thead>
            <tbody>
             <% entry[:items].each do |item| %>
  <% sport_base = ["sport_tshirt", "jogging", "sport_socks"].include?(item.name) %>
  <tr data-controller="packing-item"
      data-packing-item-id-value="<%= item.id %>"
      data-packing-item-points-value="<%= item.volume_points %>"
      <%= sport_base ? "data-sport-base-item=\"#{item.name}\" data-base-qty=\"#{item.quantity}\"".html_safe : "" %>>
    <td><%= item.name.titleize %></td>
    <td>
      <div style="display:flex; align-items:center; gap:8px;">
        <button type="button" class="ssc-counter-btn" style="width:24px; height:24px; font-size:14px;"
                data-action="click->packing-item#decrement">−</button>
        <span class="ssc-qty-badge" data-packing-item-target="quantity"><%= item.quantity %></span>
        <button type="button" class="ssc-counter-btn" style="width:24px; height:24px; font-size:14px;"
                data-action="click->packing-item#increment">+</button>
      </div>
    </td>
    <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
  </tr>
    <% end %>

              <tr data-evening-item="outfit" style="display:none;">
                <td>👗 Woman Evening Outfit</td>
                <td><span class="ssc-qty-badge" data-qty>0</span></td>
                <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
              </tr>
              <tr data-evening-item="shoes" style="display:none;">
                <td>👠 Evening Shoes</td>
                <td><span class="ssc-qty-badge" data-qty>0</span></td>
                <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
              </tr>

              <% unless has_basket || @trip.sport %>
                <tr data-sport-item="sport_tshirt" style="display:none;">
                  <td>🏃 Sport T-Shirt</td>
                  <td><span class="ssc-qty-badge" data-qty>0</span></td>
                  <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
                </tr>
                <tr data-sport-item="jogging" style="display:none;">
                  <td>🏃 Jogging</td>
                  <td><span class="ssc-qty-badge" data-qty>0</span></td>
                  <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
                </tr>
                <tr data-sport-item="sport_socks" style="display:none;">
                  <td>🧦 Sport Socks</td>
                  <td><span class="ssc-qty-badge" data-qty>0</span></td>
                  <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
                </tr>
              <% end %>

              <% unless has_basket %>
                <tr data-sport-item="basket" style="display:none;">
                  <td>👟 Basket</td>
                  <td><span class="ssc-qty-badge" data-qty>1</span></td>
                  <td><input type="checkbox" style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"></td>
                </tr>
              <% end %>
            </tbody>
          </table>

          <% if entry[:traveler].role == "adult" %>
            <div class="ssc-optional-section">
              <div class="ssc-optional-label">👗 Women's Evening Outfit</div>
              <div class="ssc-optional-control">
                <span class="ssc-optional-name">Add an outfit</span>
                <div class="ssc-counter">
                  <button type="button" class="ssc-counter-btn" data-action="click->accessories#decrementEvening">−</button>
                  <span class="ssc-counter-value" data-accessories-target="eveningCount">0</span>
                  <button type="button" class="ssc-counter-btn" data-action="click->accessories#incrementEvening">+</button>
                </div>
              </div>
            </div>
          <% end %>

          <% if @trip.sport || !is_main %>
            <div class="ssc-optional-section">
              <div class="ssc-optional-label">🏃 Extra Sport Set</div>
              <div class="ssc-optional-control">
                <span class="ssc-optional-name">Add a sport set</span>
                <div class="ssc-counter">
                  <button type="button" class="ssc-counter-btn" data-action="click->accessories#decrementSport">−</button>
                  <span class="ssc-counter-value" data-accessories-target="sportCount">0</span>
                  <button type="button" class="ssc-counter-btn" data-action="click->accessories#incrementSport">+</button>
                </div>
              </div>
            </div>
          <% end %>

        </div>
      <% end %>

      <!-- Optional Accessories -->
      <div class="ssc-card">
        <div class="ssc-card-title"><i class="bi bi-bag-plus"></i> Optional Accessories</div>
        <table class="ssc-table">
          <tbody>
            <tr>
              <td>Hair Dryer</td><td></td>
              <td><input type="checkbox" data-accessories-target="item" data-points="12"
                   style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"
                   data-action="change->accessories#update"></td>
            </tr>
            <tr>
              <td>Hair Straightener</td><td></td>
              <td><input type="checkbox" data-accessories-target="item" data-points="6"
                   style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"
                   data-action="change->accessories#update"></td>
            </tr>
            <tr>
              <td>Laptop</td><td></td>
              <td><input type="checkbox" data-accessories-target="item" data-points="6"
                   style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"
                   data-action="change->accessories#update"></td>
            </tr>
            <tr>
              <td>Tablet</td><td></td>
              <td><input type="checkbox" data-accessories-target="item" data-points="6"
                   style="width:18px; height:18px; accent-color: var(--color-primary); cursor:pointer;"
                   data-action="change->accessories#update"></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Luggage 1 -->
      <div class="ssc-card">
        <div class="ssc-card-title"><i class="bi bi-luggage-fill"></i> <%= @trip.luggage_type.titleize %> — Luggage 1</div>

        <% percentage = (@result[:total_points].to_f / @result[:capacity] * 100).round %>

        <div class="ssc-capacity-label">
          <span class="ssc-capacity-title"><%= [@result[:total_points], @result[:capacity]].min %> / <%= @result[:capacity] %> pts</span>
          <span class="ssc-capacity-pct <%= percentage > 100 ? 'over' : '' %>"
            data-accessories-target="pct"><%= percentage %>%</span>
        </div>

        <div class="ssc-progress-track">
          <div class="ssc-progress-fill <%= percentage > 100 ? 'over' : '' %>"
               data-accessories-target="bar"
               style="width: <%= [percentage, 100].min %>%;"></div>
        </div>

        <div data-accessories-target="fitsAlert"
             style="display: <%= percentage > 100 ? 'none' : 'flex' %>;"
             class="ssc-alert success">
          <span class="ssc-alert-icon">✓</span>
          <div><strong>Everything fits!</strong> Your <%= @trip.luggage_type %> luggage is good to go.</div>
        </div>

        <div data-accessories-target="overAlert"
          style="display: <%= percentage > 100 ? 'flex' : 'none' %>;"
            class="ssc-alert danger">
          <span class="ssc-alert-icon">⚠</span>
          <div>
            <strong><span data-accessories-target="overPts"><%= @result[:total_points] - @result[:capacity] > 0 ? @result[:total_points] - @result[:capacity] : 0 %></span> pts over capacity.</strong>
            Add a second bag or remove items.
          </div>
        </div>

        <div data-accessories-target="extraBagSection"
             style="display: <%= percentage > 100 ? 'block' : 'none' %>; margin-top: 16px;">
          <div class="ssc-optional-label" style="margin-bottom: 8px;">➕ Add a second bag</div>

          <label class="ssc-bag-radio-row">
            <input type="radio" name="extra_bag"
                   data-accessories-target="extraBagRadio"
                   data-capacity="100"
                   data-label="✈️ Cabin — Luggage 2"
                   data-action="change->accessories#recalculate">
            <span class="ssc-bag-radio-label">✈️ Extra Cabin bag</span>
            <span class="ssc-bag-radio-pts">100 pts</span>
          </label>

          <label class="ssc-bag-radio-row">
            <input type="radio" name="extra_bag"
                   data-accessories-target="extraBagRadio"
                   data-capacity="250"
                   data-label="🧳 Checked — Luggage 2"
                   data-action="change->accessories#recalculate">
            <span class="ssc-bag-radio-label">🧳 Extra Checked bag</span>
            <span class="ssc-bag-radio-pts">250 pts</span>
          </label>
        </div>
      </div>

      <!-- Luggage 2 -->
      <div class="ssc-card"
           data-accessories-target="extraBagCard"
           style="display: none;">
        <div class="ssc-card-title">
          <i class="bi bi-luggage-fill"></i>
          <span data-accessories-target="extraBagLabel"></span>
        </div>

        <div class="ssc-capacity-label">
          <span class="ssc-capacity-title">
            <span data-accessories-target="extraBagUsed">0</span> /
            <span data-accessories-target="extraBagCapacity">0</span> pts
          </span>
          <span class="ssc-capacity-pct" data-accessories-target="extraBagPct">0%</span>
        </div>

        <div class="ssc-progress-track">
          <div class="ssc-progress-fill" data-accessories-target="extraBagBar" style="width: 0%;"></div>
        </div>
      </div>

      <!-- Sticky Luggage Bar — DANS le scope du controller accessories -->
      <% bar_pct = (@result[:total_points].to_f / @result[:capacity] * 100).round %>
      <div class="ssc-sticky-bar">
        <span class="ssc-sticky-bar-icon">🧳</span>
         <span class="ssc-sticky-bar-label">Luggage 1</span>
        <div class="ssc-sticky-bar-track">
          <div class="ssc-sticky-bar-fill <%= bar_pct > 100 ? 'over' : '' %>"
               data-accessories-target="miniBarFill"
               style="width: <%= [bar_pct, 100].min %>%;"></div>
        </div>
        <span class="ssc-sticky-bar-pct <%= bar_pct > 100 ? 'over' : '' %>"
              data-accessories-target="miniBarPct"><%= bar_pct %>%</span>
      </div>

      <!-- Sticky Luggage Bar 2 -->
      <div class="ssc-sticky-bar"
           data-accessories-target="miniBar2"
           style="display: none; bottom: 0;">
        <span class="ssc-sticky-bar-icon">🧳</span>
        <span class="ssc-sticky-bar-label" data-accessories-target="miniBar2Label"></span>
        <div class="ssc-sticky-bar-track">
          <div class="ssc-sticky-bar-fill"
               data-accessories-target="miniBar2Fill"
               style="width: 0%;"></div>
        </div>
        <span class="ssc-sticky-bar-pct"
              data-accessories-target="miniBar2Pct">0%</span>
      </div>

    </div>

    <!-- CTA -->
    <div class="ssc-cta" style="display:flex; gap:12px; justify-content:center;">
      <%= link_to edit_trip_path(@trip), class: "ssc-btn" do %>
        <i class="bi bi-pencil"></i> Edit Trip
      <% end %>
      <%= link_to new_trip_path, class: "ssc-btn", style: "background: var(--color-surface); color: #F0EEE8; border: 1px solid var(--color-border);" do %>
        <i class="bi bi-plus-circle"></i> New Trip
      <% end %>
    </div>

  </div>
</div>
